# Telegram: токен от @BotFather
BOT_TOKEN=

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# ID ассистента (спинтакс + HTML). По умолчанию в коде задан ваш asst_...
# ASSISTANT_ID=asst_ochis2TU72Qcdg5bEEHYfAMk

# Необязательно:
# MAX_RETRIES=3
#
# Добавляется в конец каждого сообщения к ассистенту (напоминание про формат), если модель «забывает» скобки:
# USER_MESSAGE_SUFFIX=Каждый спинтакс строго в фигурных скобках: {вариант1|вариант2|вариант3}, в том числе внутри HTML-тегов.
