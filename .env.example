# Скопируйте в .env и заполните значения.

# Telegram: токен от @BotFather
BOT_TOKEN=

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Необязательно:
# OPENAI_MODEL=gpt-4o-mini
# DEFAULT_TEMPERATURE=0.7
# MAX_RETRIES=3
#
# OpenAI Assistants (optional, recommended for your setup):
# ASSISTANT_JTBD_PARSER_ID=asst_xxx
# ASSISTANT_CREATIVE_BUILDER_ID=asst_xxx
# ASSISTANT_SPINTAX_HTML_ID=asst_xxx
